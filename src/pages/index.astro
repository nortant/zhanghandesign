---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';
import Philosophy from '../components/home/Philosophy.astro';
import CoreValue from '../components/home/CoreValue.astro';
import FeaturedProjects from '../components/home/FeaturedProjects.astro';
import HowIWork from '../components/home/HowIWork.astro';
import CtaBanner from '../components/home/CtaBanner.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);
---

<Layout
  title="张涵 — 景观施工图设计师"
  description="张涵，景观施工图设计师，专注将景观设计方案转化为清晰、实用、可施工的图纸解决方案，服务西南地区住宅、社区、酒店及滨水景观项目。"
>
  <Hero />
  <Philosophy />
  <CoreValue />
  <FeaturedProjects projects={featuredProjects} />
  <HowIWork />
  <CtaBanner />
</Layout>
