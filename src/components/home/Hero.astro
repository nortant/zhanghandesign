---
---

<section class="hero" aria-label="首页横幅">

  <!-- ── Text zone ── -->
  <div class="hero__text-zone">
    <div class="hero__text-bg" aria-hidden="true">
      <img
        src="https://picsum.photos/seed/zhanghan-bg-dark/1920/600"
        alt=""
        width="1920"
        height="600"
        fetchpriority="high"
        loading="eager"
      />
      <div class="hero__text-overlay"></div>
    </div>

    <div class="hero__content container">
      <div class="hero__meta reveal">
        <span class="label label-accent">景观施工图设计</span>
        <span class="label hero__meta-en">Landscape Construction Drawing</span>
      </div>

      <h1 class="hero__headline reveal reveal-delay-1">
        <span class="hero__name">Han Zhang</span>
        <span class="hero__name-cn">张涵</span>
        <span class="hero__tagline">将景观设计意图转化为<br>清晰、实用、可施工的图纸解决方案</span>
      </h1>

      <div class="hero__cta reveal reveal-delay-2">
        <a href="/projects" class="btn-primary">
          查看项目案例
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/#how-i-work" class="btn-ghost">了解工作方式</a>
      </div>
    </div>
  </div>

  <!-- ── Three-panel workflow strip ── -->
  <div class="hero__strip" aria-label="工作流程示意">

    <!-- Panel 1: 效果图 -->
    <div class="panel panel--render">
      <img
        src="https://picsum.photos/seed/landscape-render-warm/1200/900"
        alt="景观方案效果图"
        width="1200"
        height="900"
        loading="eager"
        fetchpriority="high"
      />
      <div class="panel__shade panel__shade--warm"></div>
      <div class="panel__label">
        <span class="panel__num" aria-hidden="true">01</span>
        <span class="panel__zh">效果图</span>
        <span class="panel__en">Design Rendering</span>
        <span class="panel__desc">设计意图</span>
      </div>
    </div>

    <!-- Connector -->
    <div class="connector" aria-hidden="true">
      <div class="connector__line"></div>
      <svg class="connector__arrow" width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M4 10h12M12 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

    <!-- Panel 2: 施工图 -->
    <div class="panel panel--drawing">
      <img
        src="https://picsum.photos/seed/blueprint-detail-arch/1200/900"
        alt="景观施工图纸"
        width="1200"
        height="900"
        loading="eager"
      />
      <div class="panel__shade panel__shade--blueprint"></div>
      <div class="panel__grid-lines" aria-hidden="true"></div>
      <div class="panel__label">
        <span class="panel__num" aria-hidden="true">02</span>
        <span class="panel__zh">施工图</span>
        <span class="panel__en">Construction Drawing</span>
        <span class="panel__desc">技术转化</span>
      </div>
    </div>

    <!-- Connector -->
    <div class="connector" aria-hidden="true">
      <div class="connector__line"></div>
      <svg class="connector__arrow" width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M4 10h12M12 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

    <!-- Panel 3: 实景 -->
    <div class="panel panel--built">
      <img
        src="https://picsum.photos/seed/built-landscape-real/1200/900"
        alt="景观建成实景"
        width="1200"
        height="900"
        loading="eager"
      />
      <div class="panel__shade panel__shade--built"></div>
      <div class="panel__label">
        <span class="panel__num" aria-hidden="true">03</span>
        <span class="panel__zh">实景</span>
        <span class="panel__en">Built Reality</span>
        <span class="panel__desc">真实落地</span>
      </div>
    </div>

  </div>

  <!-- Strip caption -->
  <div class="hero__strip-caption container" aria-hidden="true">
    <span class="label" style="color: rgba(255,255,255,0.3); letter-spacing: 0.15em;">从构想到落地，每一步都有据可循</span>
  </div>

</section>

<style>
/* ── Hero shell ── */
.hero {
  display: flex;
  flex-direction: column;
  background: oklch(14% 0.01 60);
  overflow: hidden;
}

/* ── Text zone ── */
.hero__text-zone {
  position: relative;
  min-height: clamp(420px, 52vh, 600px);
  display: flex;
  align-items: center;
}

.hero__text-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.hero__text-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transform: scale(1.04);
  animation: hero-scale 14s ease-out forwards;
}

@keyframes hero-scale {
  to { transform: scale(1); }
}

.hero__text-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    105deg,
    oklch(14% 0.01 60 / 0.88) 0%,
    oklch(14% 0.01 60 / 0.65) 55%,
    oklch(14% 0.01 60 / 0.35) 100%
  );
}

.hero__content {
  position: relative;
  z-index: 1;
  padding-top: 5rem;
  padding-bottom: 3rem;
  color: white;
  max-width: 720px;
}

.hero__meta {
  display: flex;
  align-items: center;
  gap: var(--space-6);
  margin-bottom: var(--space-10);
}

.hero__meta-en {
  color: rgba(255,255,255,0.35);
  margin-left: 0;
}

.hero__headline {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  margin-bottom: var(--space-12);
}

.hero__name {
  font-family: var(--font-serif-en);
  font-size: clamp(3rem, 2rem + 4vw, 6rem);
  font-weight: 300;
  font-style: italic;
  letter-spacing: 0.02em;
  line-height: 1.0;
  color: white;
}

.hero__name-cn {
  font-family: var(--font-serif-cn);
  font-size: clamp(1.2rem, 0.8rem + 1.5vw, 2rem);
  font-weight: 300;
  letter-spacing: 0.3em;
  color: rgba(255, 255, 255, 0.5);
  margin-top: -0.5rem;
}

.hero__tagline {
  font-family: var(--font-serif-cn);
  font-size: clamp(1rem, 0.8rem + 1.2vw, 1.45rem);
  font-weight: 300;
  letter-spacing: 0.05em;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.75);
  border-left: 2px solid var(--color-accent);
  padding-left: var(--space-6);
  margin-top: var(--space-4);
}

.hero__cta {
  display: flex;
  align-items: center;
  gap: var(--space-6);
  flex-wrap: wrap;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: var(--space-3);
  padding: 0.75em 1.75em;
  background-color: var(--color-accent);
  color: white;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: 500;
  letter-spacing: 0.06em;
  border-radius: var(--radius-sm);
  transition: background-color var(--duration-normal) var(--ease-out-expo),
              transform var(--duration-normal) var(--ease-out-expo);
}

.btn-primary:hover {
  background-color: oklch(36% 0.06 145);
  transform: translateY(-2px);
}

.btn-ghost {
  display: inline-flex;
  align-items: center;
  color: rgba(255, 255, 255, 0.7);
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: 400;
  letter-spacing: 0.06em;
  border-bottom: 1px solid rgba(255, 255, 255, 0.25);
  padding-bottom: 2px;
  transition: color var(--duration-normal), border-color var(--duration-normal);
}

.btn-ghost:hover {
  color: white;
  border-color: white;
}

/* ── Three-panel strip ── */
.hero__strip {
  display: grid;
  grid-template-columns: 1fr 48px 1fr 48px 1fr;
  height: clamp(220px, 36vh, 400px);
  position: relative;
}

/* ── Individual panel ── */
.panel {
  position: relative;
  overflow: hidden;
  cursor: default;
}

.panel img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.8s var(--ease-out-expo);
}

.panel:hover img {
  transform: scale(1.05);
}

/* Shade overlays */
.panel__shade {
  position: absolute;
  inset: 0;
  transition: opacity 0.4s;
}

.panel__shade--warm {
  background: linear-gradient(
    to top,
    oklch(22% 0.05 60 / 0.85) 0%,
    oklch(22% 0.05 60 / 0.2) 55%,
    transparent 100%
  );
}

/* Blueprint effect on middle panel */
.panel--drawing img {
  filter: grayscale(85%) contrast(1.15) brightness(0.9);
}

.panel__shade--blueprint {
  background: linear-gradient(
    to top,
    oklch(18% 0.12 240 / 0.92) 0%,
    oklch(25% 0.14 240 / 0.6) 50%,
    oklch(30% 0.1 240 / 0.3) 100%
  );
  mix-blend-mode: multiply;
}

/* Subtle grid-line overlay to suggest CAD drawing */
.panel__grid-lines {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(oklch(70% 0.1 240 / 0.06) 1px, transparent 1px),
    linear-gradient(90deg, oklch(70% 0.1 240 / 0.06) 1px, transparent 1px);
  background-size: 28px 28px;
  pointer-events: none;
}

.panel__shade--built {
  background: linear-gradient(
    to top,
    oklch(18% 0.02 145 / 0.88) 0%,
    oklch(20% 0.03 145 / 0.25) 55%,
    transparent 100%
  );
}

/* Panel label (bottom of each panel) */
.panel__label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--space-6) var(--space-6) var(--space-5);
  display: flex;
  flex-direction: column;
  gap: 2px;
  z-index: 1;
}

.panel__num {
  font-family: var(--font-serif-en);
  font-style: italic;
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  color: var(--color-accent);
  margin-bottom: var(--space-2);
}

.panel__zh {
  font-family: var(--font-serif-cn);
  font-size: clamp(1.1rem, 0.9rem + 0.8vw, 1.6rem);
  font-weight: 300;
  letter-spacing: 0.1em;
  color: white;
  line-height: 1;
}

.panel__en {
  font-family: var(--font-sans);
  font-size: clamp(0.5rem, 0.4rem + 0.4vw, 0.7rem);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.45);
  margin-top: 3px;
}

.panel__desc {
  font-family: var(--font-serif-cn);
  font-size: var(--text-xs);
  color: rgba(255, 255, 255, 0.35);
  letter-spacing: 0.12em;
  margin-top: var(--space-2);
}

/* Hover: brighten the label */
.panel:hover .panel__zh { color: white; }
.panel:hover .panel__desc { color: rgba(255,255,255,0.55); }

/* ── Connector columns ── */
.connector {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: var(--space-6);
  gap: var(--space-2);
  background: oklch(16% 0.01 60);
  color: rgba(255, 255, 255, 0.25);
  position: relative;
  z-index: 2;
}

.connector__line {
  flex: 1;
  width: 1px;
  background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.12), rgba(255,255,255,0.12));
  margin-bottom: var(--space-2);
}

.connector__arrow {
  color: var(--color-accent);
  opacity: 0.7;
  flex-shrink: 0;
}

/* ── Strip caption ── */
.hero__strip-caption {
  padding-block: var(--space-4);
  background: oklch(12% 0.01 60);
  border-top: 1px solid rgba(255,255,255,0.06);
}

/* ── Responsive ── */
@media (max-width: 900px) {
  .hero__strip {
    grid-template-columns: 1fr 36px 1fr 36px 1fr;
    height: clamp(180px, 28vh, 280px);
  }
  .panel__label { padding: var(--space-4); }
}

@media (max-width: 640px) {
  .hero__meta { flex-direction: column; align-items: flex-start; gap: var(--space-2); }
  .hero__meta-en { display: none; }
  .hero__strip {
    grid-template-columns: 1fr 28px 1fr 28px 1fr;
    height: clamp(140px, 32vw, 220px);
  }
  .connector__line { display: none; }
  .panel__en, .panel__desc { display: none; }
  .hero__strip-caption { display: none; }
}
</style>
