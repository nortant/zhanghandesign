---
// Full-screen hero with giant serif headline
---

<section class="hero" aria-label="首页横幅">
  <div class="hero__bg">
    <img
      src="https://picsum.photos/seed/zhanghan-hero/1920/1080"
      alt=""
      aria-hidden="true"
      width="1920"
      height="1080"
      fetchpriority="high"
      loading="eager"
    />
    <div class="hero__overlay"></div>
  </div>

  <div class="hero__content container">
    <div class="hero__meta reveal">
      <span class="label label-accent">景观 · 建筑 · 自然</span>
      <span class="label" style="color: rgba(255,255,255,0.45); margin-left: var(--space-6)">Landscape · Architecture · Nature</span>
    </div>

    <h1 class="hero__headline reveal reveal-delay-1">
      <span class="hero__headline-cn">以自然之力</span>
      <span class="hero__headline-cn">塑造人居之境</span>
      <span class="hero__headline-en h-en">Shaping Human Space<br>with the Force of Nature</span>
    </h1>

    <div class="hero__cta reveal reveal-delay-2">
      <a href="/projects" class="btn-primary">
        探索作品
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="/about" class="btn-ghost">了解张涵</a>
    </div>
  </div>

  <div class="hero__scroll-hint" aria-hidden="true">
    <div class="hero__scroll-line"></div>
    <span class="label">向下探索</span>
  </div>
</section>

<style>
.hero {
  position: relative;
  height: 100svh;
  min-height: 600px;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}

.hero__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.hero__bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transform: scale(1.05);
  animation: hero-scale 12s ease-out forwards;
}

@keyframes hero-scale {
  to { transform: scale(1); }
}

.hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    oklch(14% 0.01 60 / 0.85) 0%,
    oklch(14% 0.01 60 / 0.4) 40%,
    oklch(14% 0.01 60 / 0.15) 100%
  );
}

.hero__content {
  position: relative;
  z-index: 1;
  padding-bottom: clamp(3rem, 8vw, 7rem);
  color: white;
}

.hero__meta {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-8);
}

.hero__headline {
  display: flex;
  flex-direction: column;
  gap: 0.1em;
  margin-bottom: var(--space-12);
}

.hero__headline-cn {
  font-family: var(--font-serif-cn);
  font-size: var(--text-hero);
  font-weight: 300;
  letter-spacing: 0.06em;
  line-height: 1.0;
  color: white;
}

.hero__headline-en {
  font-size: clamp(1rem, 0.8rem + 1.2vw, 1.6rem);
  font-weight: 300;
  letter-spacing: 0.04em;
  color: rgba(255, 255, 255, 0.55);
  margin-top: var(--space-4);
  line-height: 1.5;
}

.hero__cta {
  display: flex;
  align-items: center;
  gap: var(--space-6);
  flex-wrap: wrap;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: var(--space-3);
  padding: 0.75em 1.75em;
  background-color: var(--color-accent);
  color: white;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: 500;
  letter-spacing: 0.08em;
  border-radius: var(--radius-sm);
  transition: background-color var(--duration-normal) var(--ease-out-expo),
              transform var(--duration-normal) var(--ease-out-expo);
}

.btn-primary:hover {
  background-color: oklch(36% 0.06 145);
  transform: translateY(-2px);
}

.btn-ghost {
  display: inline-flex;
  align-items: center;
  color: rgba(255, 255, 255, 0.75);
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: 400;
  letter-spacing: 0.06em;
  border-bottom: 1px solid rgba(255, 255, 255, 0.3);
  padding-bottom: 2px;
  transition: color var(--duration-normal), border-color var(--duration-normal);
}

.btn-ghost:hover {
  color: white;
  border-color: white;
}

.hero__scroll-hint {
  position: absolute;
  bottom: var(--space-8);
  right: var(--container-pad);
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-3);
  color: rgba(255, 255, 255, 0.45);
  animation: scroll-hint-fade 2s 2s ease-out both;
}

@keyframes scroll-hint-fade {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

.hero__scroll-line {
  width: 1px;
  height: 48px;
  background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.45));
  animation: scroll-line 2s 2.5s ease-in-out infinite;
}

@keyframes scroll-line {
  0%   { transform: scaleY(0); transform-origin: top; }
  50%  { transform: scaleY(1); transform-origin: top; }
  50.01% { transform: scaleY(1); transform-origin: bottom; }
  100% { transform: scaleY(0); transform-origin: bottom; }
}

@media (max-width: 640px) {
  .hero__scroll-hint { display: none; }
  .hero__meta { flex-direction: column; align-items: flex-start; gap: var(--space-2); }
}
</style>
