---
import ProjectCard from '../ui/ProjectCard.astro';

interface Props {
  projects: Array<{
    slug: string;
    data: {
      title: string;
      titleEn: string;
      category: string;
      location: string;
      year: number;
      cover: string;
    };
  }>;
}

const { projects } = Astro.props;
---

<section class="featured" aria-labelledby="featured-heading">
  <div class="container">
    <div class="featured__header reveal">
      <div class="featured__header-text">
        <p class="label label-accent">精选项目</p>
        <h2 id="featured-heading" class="h-2xl">代表作品</h2>
      </div>
      <a href="/projects" class="featured__all-link">
        <span>查看全部项目</span>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="featured__bento">
      {projects[0] && (
        <div class="bento-cell bento-cell--hero">
          <ProjectCard
            title={projects[0].data.title}
            titleEn={projects[0].data.titleEn}
            category={projects[0].data.category}
            location={projects[0].data.location}
            year={projects[0].data.year}
            cover={projects[0].data.cover}
            slug={projects[0].slug}
            variant="large"
          />
        </div>
      )}
      {projects[1] && (
        <div class="bento-cell bento-cell--tall">
          <ProjectCard
            title={projects[1].data.title}
            titleEn={projects[1].data.titleEn}
            category={projects[1].data.category}
            location={projects[1].data.location}
            year={projects[1].data.year}
            cover={projects[1].data.cover}
            slug={projects[1].slug}
            variant="default"
          />
        </div>
      )}
      {projects[2] && (
        <div class="bento-cell bento-cell--wide">
          <ProjectCard
            title={projects[2].data.title}
            titleEn={projects[2].data.titleEn}
            category={projects[2].data.category}
            location={projects[2].data.location}
            year={projects[2].data.year}
            cover={projects[2].data.cover}
            slug={projects[2].slug}
            variant="default"
          />
        </div>
      )}
      {projects[3] && (
        <div class="bento-cell bento-cell--square">
          <ProjectCard
            title={projects[3].data.title}
            titleEn={projects[3].data.titleEn}
            category={projects[3].data.category}
            location={projects[3].data.location}
            year={projects[3].data.year}
            cover={projects[3].data.cover}
            slug={projects[3].slug}
            variant="small"
          />
        </div>
      )}
    </div>
  </div>
</section>

<style>
.featured {
  padding-block: var(--space-section);
  background: var(--color-bg-alt);
}

.featured__header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: var(--space-12);
  gap: var(--space-8);
  flex-wrap: wrap;
}

.featured__header-text {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.featured__all-link {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  color: var(--color-ink-muted);
  letter-spacing: 0.04em;
  border-bottom: 1px solid transparent;
  padding-bottom: 2px;
  transition: color var(--duration-normal), border-color var(--duration-normal);
  white-space: nowrap;
}

.featured__all-link:hover {
  color: var(--color-accent);
  border-color: var(--color-accent);
}

/* Bento grid */
.featured__bento {
  display: grid;
  grid-template-columns: 7fr 4fr;
  grid-template-rows: auto auto;
  gap: var(--space-4);
}

.bento-cell--hero {
  grid-column: 1;
  grid-row: 1 / 3;
}

.bento-cell--tall {
  grid-column: 2;
  grid-row: 1;
}

.bento-cell--wide {
  grid-column: 1;
  grid-row: 3;
}

.bento-cell--square {
  grid-column: 2;
  grid-row: 2 / 4;
}

/* Ensure cards fill their bento cells */
.bento-cell {
  min-height: 0;
}

.bento-cell :global(.project-card) {
  height: 100%;
}

@media (max-width: 900px) {
  .featured__bento {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto;
  }

  .bento-cell--hero {
    grid-column: 1 / 3;
    grid-row: auto;
  }

  .bento-cell--tall,
  .bento-cell--wide,
  .bento-cell--square {
    grid-column: auto;
    grid-row: auto;
  }
}

@media (max-width: 600px) {
  .featured__bento {
    grid-template-columns: 1fr;
  }

  .bento-cell--hero {
    grid-column: 1;
  }
}
</style>
