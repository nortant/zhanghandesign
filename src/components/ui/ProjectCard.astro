---
interface Props {
  title: string;
  titleEn: string;
  category: string;
  location: string;
  year: number;
  cover: string;
  slug: string;
  variant?: 'default' | 'large' | 'small';
}

const { title, titleEn, category, location, year, cover, slug, variant = 'default' } = Astro.props;
---

<article class:list={['project-card', `project-card--${variant}`, 'reveal']}>
  <a href={`/projects/${slug}`} class="card-link" aria-label={`查看项目：${title}`}>
    <div class="card-image">
      <img
        src={cover}
        alt={title}
        loading="lazy"
        decoding="async"
        width="1200"
        height={variant === 'small' ? 800 : 900}
      />
      <div class="card-overlay"></div>
    </div>
    <div class="card-body">
      <span class="card-category label">{category}</span>
      <h3 class="card-title">{title}</h3>
      <p class="card-title-en h-en">{titleEn}</p>
      <div class="card-meta">
        <span>{location}</span>
        <span>{year}</span>
      </div>
      <span class="card-arrow" aria-hidden="true">→</span>
    </div>
  </a>
</article>

<style>
  .project-card {
    position: relative;
    overflow: hidden;
    background-color: var(--color-dark);
  }

  .card-link {
    display: block;
    height: 100%;
  }

  .card-image {
    position: relative;
    width: 100%;
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .project-card--large .card-image {
    aspect-ratio: 16 / 10;
  }

  .project-card--small .card-image {
    aspect-ratio: 3 / 4;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out-expo);
  }

  .card-link:hover .card-image img {
    transform: scale(1.04);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      color-mix(in oklch, var(--color-dark) 75%, transparent) 0%,
      color-mix(in oklch, var(--color-dark) 20%, transparent) 50%,
      transparent 100%
    );
  }

  .card-body {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-6);
    color: white;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .card-category {
    color: var(--color-accent-light);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    margin-bottom: var(--space-2);
  }

  .card-title {
    font-family: var(--font-serif-cn);
    font-size: var(--text-lg);
    font-weight: 400;
    letter-spacing: 0.05em;
    color: white;
    line-height: 1.2;
  }

  .project-card--large .card-title {
    font-size: var(--text-xl);
  }

  .card-title-en {
    font-family: var(--font-serif-en);
    font-size: var(--text-sm);
    font-style: italic;
    color: color-mix(in oklch, white 60%, transparent);
    margin-bottom: var(--space-3);
  }

  .card-meta {
    display: flex;
    gap: var(--space-4);
    font-size: var(--text-xs);
    color: color-mix(in oklch, white 55%, transparent);
    font-family: var(--font-sans);
    letter-spacing: 0.05em;
  }

  .card-arrow {
    position: absolute;
    top: var(--space-6);
    right: var(--space-6);
    font-size: 1.2rem;
    color: white;
    opacity: 0;
    transform: translate(-6px, 6px);
    transition:
      opacity var(--duration-normal) var(--ease-out-expo),
      transform var(--duration-normal) var(--ease-out-expo);
  }

  .card-link:hover .card-arrow {
    opacity: 1;
    transform: translate(0, 0);
  }
</style>
